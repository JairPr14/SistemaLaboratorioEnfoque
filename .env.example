# ===========================================
# DESARROLLO (PostgreSQL local con Docker)
# ===========================================
# 1. Iniciar contenedor: docker compose up -d
# 2. Usar estas URLs en .env para desarrollo local
# 3. Los datos no afectan la BD de producción
#
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sistema_lab_dev"
SHADOW_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postgres"

# ===========================================
# PRODUCCIÓN / DESPLIEGUE
# ===========================================
# Sustituir por tu conexión real (Seenode, Neon, etc.)
# Ejemplo:
# DATABASE_URL="postgresql://user:pass@host:5432/db?sslmode=require"
# SHADOW_DATABASE_URL="postgresql://user:pass@host:5432/postgres?sslmode=require"
#
# DATABASE_URL=
# SHADOW_DATABASE_URL=

# ===========================================
# NextAuth (común a dev y prod)
# ===========================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="genera-una-clave-segura-con-openssl-rand-base64-32"
