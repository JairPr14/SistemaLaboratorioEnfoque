# ===========================================
# DESARROLLO LOCAL (copia a .env)
# ===========================================
# OBLIGATORIO: Usa Docker para desarrollo. Seenode en local causa "too many connections"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sistema_lab_dev"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/sistema_lab_dev"
SHADOW_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postgres"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="genera-una-clave-con-openssl-rand-base64-32"

# Si usas Seenode en desarrollo (no recomendado): PRISMA_CONNECTION_LIMIT=1
# Usar BD de producción en desarrollo (pruebas): DATABASE_USE_PRODUCTION=1

# ===========================================
# PRODUCCIÓN (Vercel + Seenode/Neon)
# ===========================================
# Configurar en: Vercel → Settings → Environment Variables
# Obligatorias: DATABASE_URL, DIRECT_URL, NEXTAUTH_URL, NEXTAUTH_SECRET
# DIRECT_URL: igual que DATABASE_URL para Seenode (no tiene pooler separado)
# Recomendado para Seenode (evitar saturación): PRISMA_CONNECTION_LIMIT=1
# Ver DEPLOYMENT.md y VERCEL_DATABASE.md
